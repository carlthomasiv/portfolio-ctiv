.single_image img {
	Padding: 0px;
	border-radius: 8px;
}

code {
	font-family: "JetBrains Mono", "Courier New", monospace;
	color: #010101;
	Font-weight: 500;
	Background-color: #ededed;
	padding-left: 6px;
	Padding-right: 6px
}

.slideshow-border-box .flexslider {
    border: 1px solid #dddddd;
    border-radius: 6px;
	    overflow: hidden;
}

#metric-data-point h2 {
	margin-bottom: 0px;
	font-weight:bold;
}

#header {
	box-shadow: none!important;
}

.about-me-summary p, .about-me-summary ul {
	font-size: 16px;
}

#data-point {
	   padding: 20px;
    border: 1px solid #e4e4e4;
    border-radius: 6px;
}

#data-point h2 {
	margin-bottom: 0px;
}

blockquote {
    color: #7a7a7a;
}

.home .minor-spacing {
	margin-bottom:12px!important;
	margin-top: 12px;
  color: #333333;
}

.home-text-welcome {
	font-size: 20px;
}

.logo a {
	color: #333;
    font-weight: normal;
/* 	text-transform:uppercase; */
}

.logo a:hover {
	color: #0072C6;
	transition: color 0.15s ease-out;
}

a:hover,
li:hover a {
	transition: color 0.15s ease-out;
}

#navigation > ul > li > a,
h4,
h1,
h2,
#fullimagecenter h1, #transparentimage h1, #fullimagecenter .title-h1, #transparentimage .title-h1,
.portfolio-item h4 a {
	font-weight: normal;
}

#navigation > ul > li > a {
	transition: color 0.15s ease-out;
}

.header-v1 #navigation > ul > li {
	padding-left: 16px;
	padding-right: 16px;
}
.header-v1 #navigation > ul > li a {
	padding: 2px 0 2px 0;
}

.header-v1 #navigation > ul > li.current_page_item a {
	border-bottom: 1px solid #1f2327;
}

