	font-size: 16px;
	text-align: left;
	text-transform:none;
	font-weight: 600;
}
.portfolio-item h4 a {
	font-weight:600;
}

.quote {
	   font-style: italic;
    color: #666666;
    font-weight: normal;
}

.border div.flexslider {
	border: 1px solid #dadada;
	overflow: hidden;
	border-radius: 8px;
}
.no-margin-removed div.flexslider {
	margin-bottom: 0px!important;
}
div.condensed-content p {
	font-size: 12px;
	font-style: italic;
}

.metrics-area {
	margin-bottom: 0px!important;
}
.metrics-area h2 {
	margin-bottom: 0px!important;
	Font-weight: Bold;
	color: #777777;
}
.metrics-top-section {
	Margin-bottom: 20px!important;
}

.portfolio-wide .flexslider {
	Margin-bottom: 0px;
}
div.no-margin-bottom {
	margin-bottom: 8px!important;
