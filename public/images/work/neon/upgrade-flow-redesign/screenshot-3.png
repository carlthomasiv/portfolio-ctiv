/* Custom divider code adjust */
.divider-title.align-center {
    text-align: center;
    margin: 0 auto;
    margin: 0 auto 0px 0 !important;
}

.divider-title.align-center:after {
    background-color: #efefef;
    content: "";
    display: inline-block;
    height: 2px;
    width: 100%;
    position: relative;
    left: inherit;
    margin-left: 0;
    bottom: 0;
}

h4 a {
    color: #0072c6;
}

.col-link h4 a::after {
	content:' →';
}

.header-video .col {
/*	width: 100%;
	max-width: 1200px; */
	margin: 0px auto;
	text-align: center;
}

.home-summary {
	margin-bottom: 24px!important;
}

.header-icons {
display: none;
}

.portfolio-overlay-name .portfolio-overlay span {
    text-align: left;
}

.portfolio-text {
	margin-bottom: 24px;
	font-size: 16px;
}

.page-id-335 .video-wrap video {
	margin-top: 60px;
}

.lets-work-together a {
	color: #555555;
}

.lets-work-together a:hover {
	color: #3d8dc6;
}

.vc_responsive .wpb_row .vc_col-sm-4 {
