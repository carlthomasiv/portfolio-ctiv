	margin-bottom: 24px;
	font-size: 16px;
}

.lets-work-together {
	display: none;
}

.portfolio-design-paragraphs {
	font-size: 16px;
    margin-bottom: 20px;
}

#goal-quote {
	font-size: 22px;
}

.port-image img {
	border: 1px solid #efefef;
}

.wireframe-images {
	margin-bottom: 8px;
}

.entry-image,
.single-post .titlebar {Display: none;}
#no-top-margin {
	Margin-top: -30px!important;
}

.header-no-padding {
	margin-bottom: 0px!important;
}

h2 a {
	color: #0072c6;
}

.about-condensed-paragraphs {
	margin-bottom: 20px;
}
.about-condensed-paragraphs h3 {
	margin-bottom: 12px;
}
.portfolio-text p {
	margin-bottom: 12px;
}

/* Portfolio tiles */
.portfolio-overlay-name .portfolio-overlay {
	Background-color: rgba(255,255,255,0.15)!important;
}
.portfolio-overlay-name .portfolio-overlay span {
	/*Display: none!important;*/
